# Stalcraft Market Analyzer - example environment file
#
# Usage:
# - Copy to ".env" and fill in values
# - Do NOT commit ".env" to git

# StalcraftDB base URL.
# Recommended (EU): https://stalcraftdb.net/eu
STALCRAFTDB_BASE_URL=https://stalcraftdb.net/eu

# Database URL (SQLite default).
# You can keep this default for MVP.
DATABASE_URL=sqlite:///data/market.db

# Where raw snapshots are written (optional).
RAW_OUTPUT_DIR=./data/raw

# Optional Dev UI password.
# If set, Dev UI requires browser Basic Auth (username can be anything, password = this token).
# User Web does not use this token and remains read-only.
DEV_UI_TOKEN=

# Optional artifact rarity override file.
# StalcraftDB listing currently does not expose artifact transaction quality directly.
# Format: JSON object {"item_id": "gold"} or list [{"item_id": "...", "rarity": "gold"}].
ARTIFACT_RARITY_OVERRIDES_FILE=./data/artifact_rarity_overrides.json

# Public EXBO item database enrichment (no token required).
# Uses https://github.com/EXBO-Studio/stalcraft-database to fill artifact rarity from item JSON.
EXBO_ITEM_DB_ENABLED=true
EXBO_ITEM_DB_REALM=global
EXBO_ITEM_DB_CACHE_FILE=./data/exbo_artifact_rarities.json

# Optional official EXBO / STALCRAFT API integration.
# When configured, ingestion tries EXBO first and requests auction history/lots with additional=true.
# OpenAPI contract: https://eapi.stalcraft.net/openapi
# Public endpoints work without credentials, auction endpoints declare AppAuth in OpenAPI.
EXBO_API_BASE_URL=https://eapi.stalcraft.net
EXBO_REGION=EU
EXBO_ACCESS_TOKEN=
EXBO_CLIENT_ID=
EXBO_CLIENT_SECRET=

# Discord Webhook URL (required to send alerts).
# Create in Discord: Channel Settings -> Integrations -> Webhooks -> New Webhook.
DISCORD_WEBHOOK_URL=

# Webhook request timeout in seconds (float).
# Default used by code: 10.0
DISCORD_WEBHOOK_TIMEOUT_S=10

# Maximum number of retries after the initial attempt (int).
# Total attempts = 1 + DISCORD_WEBHOOK_MAX_RETRIES
# Default used by code: 3
DISCORD_WEBHOOK_MAX_RETRIES=3

# Exponential backoff base delay in seconds (float).
# Actual sleep = DISCORD_WEBHOOK_RETRY_BACKOFF_S * (2 ** attempt_index)
# Default used by code: 0.8
DISCORD_WEBHOOK_RETRY_BACKOFF_S=0.8

# Spam control for price anomaly Discord sends (per item_id):
# If a price_anomaly alert row exists in SQLite within the last N minutes, the scan skips sending another.
PRICE_ALERT_COOLDOWN_MINUTES=60

# Patch impact (optional LLM via OpenAI Chat Completions JSON mode)
PATCH_IMPACT_LLM_ENABLED=false
OPENAI_API_KEY=
PATCH_IMPACT_LLM_MODEL=gpt-5.2-mini

# Gate for patch Discord broadcast:
# Only BUFF/NERF with confidence >= this threshold will be posted.
PATCH_DISCORD_MIN_CONFIDENCE=0.55

