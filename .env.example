# Stalcraft Market Analyzer - example environment file
#
# Usage:
# - Copy to ".env" and fill in values
# - Do NOT commit ".env" to git

# Discord Webhook URL (required to send alerts).
# Create in Discord: Channel Settings -> Integrations -> Webhooks -> New Webhook.
DISCORD_WEBHOOK_URL=

# Webhook request timeout in seconds (float).
# Default used by code: 10.0
DISCORD_WEBHOOK_TIMEOUT_S=10

# Maximum number of retries after the initial attempt (int).
# Total attempts = 1 + DISCORD_WEBHOOK_MAX_RETRIES
# Default used by code: 3
DISCORD_WEBHOOK_MAX_RETRIES=3

# Exponential backoff base delay in seconds (float).
# Actual sleep = DISCORD_WEBHOOK_RETRY_BACKOFF_S * (2 ** attempt_index)
# Default used by code: 0.8
DISCORD_WEBHOOK_RETRY_BACKOFF_S=0.8

